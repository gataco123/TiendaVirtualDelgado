

@model List<TiendaVirtualDelgado.Models.Producto>

<h2>Lista de Productos</h2>

<a class="btn btn-success mb-3" href="/Producto/Create">+ Nuevo Producto</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Categoría</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Precio</td>
                <td>@item.Stock</td>
                <td>@item.Categoria?.Nombre</td>

                <td>
                    <a class="btn btn btn-warning"
                       href="/Producto/Edit/@item.Id">Editar</a>

                    @if (Context.Session.GetString("Rol")=="admin")
                    { <a class= "btn btn btn-danger"
                       href = "/Producto/Delete/@item.Id" > Eliminar </a >}
                    
                </td>
            </tr>
        }
    </tbody>
</table>